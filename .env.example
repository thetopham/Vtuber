# Controller
CONTROLLER_PORT=8787
WS_PATH=/ws
CORS_ORIGIN=*

# VTube Studio
VTS_WS_URL=ws://127.0.0.1:8001
# Optional: pre-generated plugin token, otherwise controller stores token in VTS_TOKEN_PATH after first auth.
VTS_AUTH_TOKEN=
VTS_TOKEN_PATH=.vtube-token

# Overlay (Vite reads VITE_*)
VITE_CONTROLLER_PORT=8787
VITE_WS_PATH=/ws
