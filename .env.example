# Controller
CONTROLLER_PORT=8787
WS_PATH=/ws
CORS_ORIGIN=*

# Shared/fallback VTube Studio config (backward compatible)
VTS_WS_URL=ws://127.0.0.1:8001
VTS_PLUGIN_NAME=Vtuber Controller
VTS_PLUGIN_DEVELOPER=Vtuber Team
VTS_AUTH_TOKEN=

# Shared fallback hotkeys
VTS_HOTKEY_HAPPY=happy
VTS_HOTKEY_NEUTRAL=neutral
VTS_HOTKEY_ANGRY=angry
VTS_HOTKEY_APPROVAL=approval
VTS_HOTKEY_EXCITED=excited
VTS_HOTKEY_SAD=sad
VTS_HOTKEY_SHOCKED=shocked
VTS_HOTKEY_EMBARRASSED=embarrassed
VTS_HOTKEY_WINK=wink

# Performer-specific VTube Studio config (preferred)
VTS_NOVA_WS_URL=ws://127.0.0.1:8001
VTS_NOVA_AUTH_TOKEN=
VTS_NOVA_HOTKEY_HAPPY=happy
VTS_NOVA_HOTKEY_NEUTRAL=neutral
VTS_NOVA_HOTKEY_ANGRY=angry
VTS_NOVA_HOTKEY_APPROVAL=approval
VTS_NOVA_HOTKEY_EXCITED=excited
VTS_NOVA_HOTKEY_SAD=sad
VTS_NOVA_HOTKEY_SHOCKED=shocked
VTS_NOVA_HOTKEY_EMBARRASSED=embarrassed
VTS_NOVA_HOTKEY_WINK=wink

VTS_ECHO_WS_URL=ws://127.0.0.1:8002
VTS_ECHO_AUTH_TOKEN=
VTS_ECHO_HOTKEY_HAPPY=happy
VTS_ECHO_HOTKEY_NEUTRAL=neutral
VTS_ECHO_HOTKEY_ANGRY=angry
VTS_ECHO_HOTKEY_APPROVAL=approval
VTS_ECHO_HOTKEY_EXCITED=excited
VTS_ECHO_HOTKEY_SAD=sad
VTS_ECHO_HOTKEY_SHOCKED=shocked
VTS_ECHO_HOTKEY_EMBARRASSED=embarrassed
VTS_ECHO_HOTKEY_WINK=wink

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# OpenAI TTS
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova

# Overlay (Vite reads VITE_*)
VITE_CONTROLLER_PORT=8787
VITE_WS_PATH=/ws
