{
  "name": "ai-vtuber-controller-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n controller,overlay -c cyan,magenta \"npm run dev -w @vtuber/controller\" \"npm run dev -w @vtuber/overlay\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
